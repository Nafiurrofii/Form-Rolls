# Database Configuration
# Copy this file to .env and update with your credentials

DB_HOST=localhost
DB_NAME=form_roll
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# API Settings
API_DEBUG=true
API_LOG_ERRORS=true

# CORS Settings
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Pagination
DEFAULT_LIMIT=10
MAX_LIMIT=100

# Application
APP_ENV=development
APP_DEBUG=true
